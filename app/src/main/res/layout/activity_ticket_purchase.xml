<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0">

    <!-- Üst Bar -->
    <LinearLayout
        android:id="@+id/purchaseTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/dark_red"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPurchaseBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Geri"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:padding="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎟️ Bilet Al"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="60dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- FORM -->
    <ScrollView
        android:id="@+id/purchaseForm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/purchaseTopBar"
        android:layout_above="@id/btnConfirmPurchase"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Yarış adı kartı -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YARIŞ"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPurchaseRaceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yarış Adı"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bilet türü kartı -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BİLET TÜRÜ"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"/>

                    <RadioGroup
                        android:id="@+id/rgTicketType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbStandart"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="🎫  Standart  —  ₺250"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:buttonTint="@color/dark_red"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rbVip"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="⭐  VIP  —  ₺750"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:buttonTint="@color/dark_red"/>

                        <RadioButton
                            android:id="@+id/rbPitLane"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="🏁  Pit Lane  —  ₺1500"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:buttonTint="@color/dark_red"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Adet kartı -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADET"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnMinus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="-"
                            android:textSize="28sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#CCCCCC"
                            android:stateListAnimator="@null"/>

                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1"
                            android:textColor="#1A1A1A"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                        <Button
                            android:id="@+id/btnPlus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+"
                            android:textSize="28sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="@color/dark_red"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvUnitPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bilet fiyatı: ₺250 / kişi"
                        android:textColor="#999999"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tvTotalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toplam: ₺250"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Satın Al Butonu -->
    <Button
        android:id="@+id/btnConfirmPurchase"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="🎟️  BİLETİ SATIN AL"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/dark_red"
        android:stateListAnimator="@null"/>

    <!-- BAŞARI EKRANI -->
    <LinearLayout
        android:id="@+id/successLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/purchaseTopBar"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#F0F0F0"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="72sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bilet Alındı!"
            android:textColor="#1A1A1A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvSuccessRaceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yarış Adı"
            android:textColor="@color/dark_red"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvSuccessDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bilet başarıyla alındı!"
            android:textColor="#666666"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btnBackToMain"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ana Sayfaya Dön"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/dark_red"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</RelativeLayout>